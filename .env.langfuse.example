# Secrets for the self-hosted Langfuse stack (docker-compose.langfuse.yml).
# Copy to .env.langfuse and fill in. .env.langfuse is gitignored.
#
# Generate ENCRYPTION_KEY with: openssl rand -hex 32
# All other secrets should be long random strings (e.g. `openssl rand -base64 32`).

# NextAuth (signs the Langfuse web session cookies)
NEXTAUTH_SECRET=

# Encrypts API keys and other secrets at rest. MUST be 64 hex chars.
ENCRYPTION_KEY=

# Salt for hashed values
SALT=

# Postgres
POSTGRES_PASSWORD=

# Clickhouse (traces / observations / scores)
CLICKHOUSE_PASSWORD=

# Redis (queues / cache)
REDIS_AUTH=

# MinIO (S3-compatible blob storage for events and media)
MINIO_ROOT_PASSWORD=
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=
