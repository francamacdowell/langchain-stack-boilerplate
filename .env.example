# Anthropic — required
ANTHROPIC_API_KEY="sk-ant-..."

# Langfuse — required (self-hosted; see docs/specs/langfuse-integration.md)
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_SECRET_KEY="sk-lf-..."

# When the app runs on the host: http://localhost:3000
# When the app runs inside Docker and Langfuse runs in its own compose stack
# on the same host, use: http://host.docker.internal:3000
LANGFUSE_HOST="http://localhost:3000"

# Postgres — required for the persistent checkpointer (Phase 4)
POSTGRES_PASSWORD="changeme"

# Connection URI used by the FastAPI app.
# make serve (app on host, Postgres in Docker):
POSTGRES_URI="postgresql://postgres:changeme@localhost:5433/langgraph"
# make docker-up (both app and Postgres in Docker — docker-compose.yml overrides this automatically):
# POSTGRES_URI="postgresql://postgres:changeme@postgres:5432/langgraph"
